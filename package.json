    "cmdk": "^1.1.1",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.469.0",
    "mongodb": "^6.12.0",
    "mongoose": "^8.9.0",
    "next": "^15.0.0",
    "next-auth": "^4.24.11",
    "nodemon": "^3.1.14",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "stripe": "^17.5.0",
    "tailwind-merge": "^2.6.0",
